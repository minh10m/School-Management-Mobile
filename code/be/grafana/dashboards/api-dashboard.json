{
  "title": "School Management API Overview",
  "uid": "school-api-overview",
  "tags": ["api", "dotnet"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(school_api_http_server_request_duration_seconds_count[1m])",
          "legendFormat": "Requests / sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 50xxx Custom Errors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(school_api_custom_error_count_total{custom_status_code=~\"50...\"}[1m])",
          "legendFormat": "Errors / sec ({{custom_status_code}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Thread Pool Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "school_api_process_runtime_dotnet_thread_pool_threads_count",
          "legendFormat": "Threads Count",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "school_api_process_runtime_dotnet_gc_heap_size_bytes",
          "legendFormat": "Working Set",
          "refId": "A"
        }
      ]
    }
  ]
}
